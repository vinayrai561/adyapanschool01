# Adyapan environment template
# Copy to .env.local for local Next.js development or configure these in your host.
# Keep real values out of Git.

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://placeholder_user:placeholder_password@placeholder-cluster.mongodb.net/adyapan?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://placeholder_user:placeholder_password@placeholder-cluster.mongodb.net/adyapan?retryWrites=true&w=majority

# Authentication and admin access
JWT_SECRET=replace_with_random_64_hex_characters_minimum
NEXTAUTH_SECRET=replace_with_random_64_hex_characters_minimum
NEXTAUTH_URL=http://localhost:3000
COOKIE_SECRET=replace_with_random_64_hex_characters_minimum
ADMIN_EMAIL=admin@example.com
ADMIN_ACCESS_KEY=replace_with_random_admin_access_key

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=turnstile_site_key_placeholder
TURNSTILE_SECRET_KEY=turnstile_secret_key_placeholder

# Razorpay
RAZORPAY_KEY_ID=rzp_test_placeholder_key_id
RAZORPAY_KEY_SECRET=razorpay_secret_placeholder
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_placeholder_key_id
RAZORPAY_WEBHOOK_SECRET=razorpay_webhook_secret_placeholder

# Optional direct UPI display value
NEXT_PUBLIC_UPI_ID=placeholder@upi

# Email
SENDGRID_API_KEY=sendgrid_api_key_placeholder
EMAIL_FROM=noreply@example.com
EMAIL_PASS=gmail_app_password_placeholder

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=cloud_name_placeholder
CLOUDINARY_API_KEY=cloudinary_key_placeholder
CLOUDINARY_API_SECRET=cloudinary_secret_placeholder

# Backend API
BACKEND_PORT=5000
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# SEO and analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=facebook_pixel_placeholder
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=google_site_verification_placeholder
NEXT_PUBLIC_BING_SITE_VERIFICATION=bing_site_verification_placeholder
INDEXNOW_KEY=indexnow_key_placeholder
INDEXNOW_SUBMIT_SECRET=indexnow_submit_secret_placeholder

# Optional integrations
FAST2SMS_API_KEY=fast2sms_key_placeholder
OPENAI_API_KEY=openai_key_placeholder
GEMINI_API_KEY=gemini_key_placeholder

# Seed scripts only
ADMIN_NAME=Example Admin
ADMIN_PASS=replace_with_seed_admin_password
ORG_USER_1_NAME=Example Organization User
ORG_USER_1_EMAIL=org1@example.com
ORG_USER_1_PASS=replace_with_org_user_password
